generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Currency {
  CUP
  USD
  EUR
}

enum PaymentMethod {
  ENZONA
  TRANSFERMOVIL
  BANK_TRANSFER_CUP
  BANK_TRANSFER_INTL
  CRYPTO_USDT
  CRYPTO_USDC
  MANUAL
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
  REFUNDED
}

enum Visibility {
  PUBLIC
  ENROLLED_ONLY
  PRIVATE
}

enum SessionType {
  RECORDED
  LIVE
  HYBRID
}

enum CourseStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum Role {
  ADMIN
  INSTRUCTOR
  STUDENT
}

model User {
  id              String        @id @default(uuid())
  email           String        @unique
  passwordHash    String
  name            String
  role            Role          @default(STUDENT)
  country         String?
  preferredLang   String        @default("es")
  refreshTokens   RefreshToken[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  enrollments     Enrollment[]
  courses         Course[]       @relation("CourseInstructor")
  paymentsReviewed Payment[]    @relation("PaymentReviewer")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Course {
  id            String        @id @default(uuid())
  slug          String        @unique
  title         Json
  description   Json
  learningObjectives Json?
  targetAudience Json?
  requirements  Json?
  competencies  Json?
  questionBank  Json?
  estimatedHours Int?
  weeklyHours   Int?
  level         String?
  language      String        @default("es")
  certificateAvailable Boolean @default(true)
  selfPaced     Boolean       @default(true)
  visibility    Visibility    @default(PUBLIC)
  status        CourseStatus  @default(DRAFT)
  pricingModel  String        @default("FREE")
  price         Decimal?      @db.Decimal(10, 2)
  currency      Currency      @default(USD)
  instructorId  String
  instructor    User          @relation("CourseInstructor", fields: [instructorId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sessions      Session[]
  modules       CourseModule[]
  editions      CourseEdition[]
  enrollments   Enrollment[]
  certificates  Certificate[]
  evaluations   Evaluation[]

  @@index([slug, status])
  @@index([instructorId])
}

model CourseEdition {
  id          String       @id @default(uuid())
  courseId    String
  name        Json
  startsAt    DateTime?
  endsAt      DateTime?
  capacity    Int?
  status      CourseStatus @default(PUBLISHED)
  isDefault   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]

  @@index([courseId, status])
  @@index([courseId, isDefault])
}

model CourseModule {
  id          String       @id @default(uuid())
  courseId    String
  title       Json
  description Json?
  order       Int
  status      CourseStatus @default(DRAFT)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  course   Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@index([courseId, order])
}

model Session {
  id            String       @id @default(uuid())
  courseId      String
  moduleId      String?
  title         Json
  description   Json
  keywords      String[]
  sessionType   SessionType  @default(RECORDED)
  preview       Boolean      @default(false)
  videoUrl      String?
  videoPlatform String?
  durationMinutes Int?
  resources     Json?
  practicePrompt Json?
  scheduledAt   DateTime?
  order         Int
  status        CourseStatus @default(DRAFT)
  course        Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module        CourseModule? @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  completions   SessionCompletion[]

  @@index([courseId, order])
  @@index([moduleId, order])
  @@index([preview])
}

model Enrollment {
  id            String        @id @default(uuid())
  userId        String
  courseId      String
  editionId     String?
  status        String        @default("ACTIVE")
  progress      Float         @default(0.0)
  admissionType String        @default("COMMERCIAL")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  course        Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  edition       CourseEdition? @relation(fields: [editionId], references: [id], onDelete: SetNull)
  payments      Payment[]
  certificate   Certificate?
  completions   SessionCompletion[]
  evalAttempts  EvaluationAttempt[]

  @@index([userId])
  @@index([courseId, status])
  @@index([editionId])
  @@unique([userId, courseId, editionId])
}

model Payment {
  id              String        @id @default(uuid())
  enrollmentId    String
  currency        Currency
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(10, 2)
  amountReference String?
  enzonaTxId      String?
  cryptoAddress   String?
  cryptoTxHash    String?
  bankReference   String?
  proofUrl        String?
  userIp          String?
  userCountry     String?
  notes           String?
  reviewedBy      String?
  reviewedAt      DateTime?
  expiresAt       DateTime?
  createdAt       DateTime      @default(now())

  enrollment      Enrollment    @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  reviewer        User?         @relation("PaymentReviewer", fields: [reviewedBy], references: [id])

  @@index([status, currency])
  @@index([enrollmentId])
  @@index([cryptoTxHash])
}

model PaymentInstruction {
  id             String        @id @default(uuid())
  method         PaymentMethod
  currency       Currency
  label          Json
  instructions   Json
  accountInfo    Json?
  isActive       Boolean       @default(true)
  geoRestriction String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([method, currency])
  @@index([isActive])
}

model Certificate {
  id                String   @id @default(uuid())
  enrollmentId      String   @unique
  courseId          String
  studentId         String
  badgeId           String   @unique
  verificationUrl   String
  credentialSubject Json
  issuerProfile     Json
  criteriaNarrative String
  pdfUrl            String?
  imageBadgeUrl     String?
  isRevoked         Boolean  @default(false)
  revocationReason  String?
  issuedAt          DateTime @default(now())

  enrollment        Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  course            Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([studentId, issuedAt])
  @@index([courseId])
  @@index([badgeId])
}

model SessionCompletion {
  id           String   @id @default(uuid())
  enrollmentId String
  sessionId    String
  completedAt  DateTime @default(now())

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  session    Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, sessionId])
  @@index([enrollmentId])
}

model Evaluation {
  id            String  @id @default(uuid())
  courseId      String  @unique
  title         Json    // {es: "...", en: "..."}
  description   Json?   // {es: "...", en: "..."}
  passingScore  Float   @default(80.0)
  maxAttempts   Int     @default(3)
  showFeedback  Boolean @default(true)
  shuffleQuestions Boolean @default(true)
  shuffleOptions Boolean @default(true)
  questions     Json    // [{id, type:"MCQ"|"TRUEFALSE"|"SHORT", question:{es,en}, options:[{es,en}], correctAnswer, feedback:{es,en}, points}]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course    Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attempts  EvaluationAttempt[]

  @@index([courseId])
}

model EvaluationAttempt {
  id           String   @id @default(uuid())
  evaluationId String
  enrollmentId String
  answers      Json     // [{questionId, answer}]
  score        Float    // 0-100
  passed       Boolean
  submittedAt  DateTime @default(now())

  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([evaluationId, enrollmentId])
  @@index([enrollmentId])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String
  userId    String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([action, createdAt])
}
