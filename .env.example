# ============================================
# EdPlatform - Variables de Entorno
# Copiar a .env.local y completar valores
# ============================================

# Base de Datos
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/edplatform?schema=public"

# JWT
JWT_SECRET="cambiar-por-secreto-seguro-min-32-chars"
JWT_REFRESH_SECRET="cambiar-por-secreto-refresh-min-32-chars"

# EdDSA - Clave privada para firma de certificados
# Generar con: openssl genpkey -algorithm ed25519 -outform pem | base64 -w0
EDDSA_PRIVATE_KEY=""

# Storage
# local: desarrollo y fallback local
# r2: Cloudflare R2 / S3 compatible
# supabase: Supabase Storage
STORAGE_PROVIDER="local"        # "local" | "supabase" | "r2"
STORAGE_ALLOW_LOCAL_FALLBACK="true"

# Supabase Storage
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_KEY=""

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="edplatform-uploads"
# Recomendado: dominio publico/custom domain del bucket, sin slash final.
# Ejemplo: https://media.tudominio.com
R2_PUBLIC_URL=""

# Email (Resend / SMTP)
RESEND_API_KEY=""
EMAIL_FROM="noreply@edplatform.com"

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="EdPlatform"
